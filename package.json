{
  "name": "weyland-yutani-cyberdeck",
  "homepage": "https://loteknowledg.github.io/weyland-yutani-cyberdeck/",
  "version": "1.0.0",
  "description": "",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3000",
    "dev:electron": "electron main.cjs",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:electron\"",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 3000",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "tts-natasha": "node tts-natasha.js",
    "tts-natasha-play": "node tts-natasha-play.js",
    "voice:vscode": "node scripts/vscode-voice.js",
    "hook:test-mechanicus-last": "python .cursor/hooks/speak_last_sentence_mechanicus.py --self-test",
    "hook:dry-mechanicus-last": "python .cursor/hooks/speak_last_sentence_mechanicus.py --dry-run",
    "hook:smoke-mechanicus-voice": "powershell -NoProfile -Command \"Get-Content -Raw .cursor/hooks/sample-after-agent.json | python .cursor/hooks/speak_last_sentence_mechanicus.py\"",
    "mechanicus:say": "python scripts/mechanicus_say.py",
    "debug:voice-ui": "node scripts/playwright-debug-voice.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@ncdai/react-wheel-picker": "^1.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "effect": "^3.21.0",
    "just-bash": "^2.14.2",
    "lucide-react": "^1.8.0",
    "play-sound": "^1.1.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.3",
    "react-resizable": "^3.1.3",
    "react-rnd": "^10.5.3",
    "reactflow": "^11.11.4",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "gh-pages": "^6.3.0",
    "playwright": "1.50.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "vite": "8.0.3",
    "vite-plus": "^0.1.15"
  }
}
